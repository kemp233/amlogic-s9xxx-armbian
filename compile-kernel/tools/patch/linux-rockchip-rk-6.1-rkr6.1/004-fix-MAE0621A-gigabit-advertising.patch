diff --git a/drivers/net/phy/motorcomm.c b/drivers/net/phy/motorcomm.c
index 8039c4b99b71..18b9e298ea0b 100644
--- a/drivers/net/phy/motorcomm.c
+++ b/drivers/net/phy/motorcomm.c
@@ -13,6 +13,7 @@
 
 #define PHY_ID_YT8011		0x4f51eb01
 #define PHY_ID_YT8511		0x0000010a
+#define PHY_ID_MAE0621A		0x7b744411
 #define PHY_ID_YT8512		0x00000118
 #define PHY_ID_YT8512B		0x00000128
 #define PHY_ID_YT8522		0x4f51e928
@@ -764,6 +765,13 @@ static int yt8521_config_init(struct phy_device *phydev)
 	if (ret < 0)
 		return ret;
 
+	/* Force 1000M advertising: strap may limit to 100M */
+	ret = phy_modify_changed(phydev, MII_CTRL1000,
+				  ADVERTISE_1000HALF | ADVERTISE_1000FULL,
+				  ADVERTISE_1000HALF | ADVERTISE_1000FULL);
+	if (ret < 0)
+		return ret;
+
 	netdev_info(phydev->attached_dev, "%s done, phy addr: %d, strap mode = %d, polling mode = %d\n",
 		    __func__, phydev->mdio.addr, hw_strap_mode, yt8521_hw_strap_polling(phydev));
 
@@ -1202,6 +1210,17 @@ static struct phy_driver motorcomm_phy_drvs[] = {
 		.read_status	= yt8512_read_status,
 		.suspend	= genphy_suspend,
 		.resume		= genphy_resume,
+	}, {
+		/* same as 8521 - MAE0621A-Q2C OEM variant */
+		PHY_ID_MATCH_EXACT(PHY_ID_MAE0621A),
+		.name		= "MAE0621A-Q2C Gigabit Ethernet",
+		.features	= PHY_GBIT_FEATURES,
+		.flags		= PHY_POLL,
+		.config_aneg	= genphy_config_aneg,
+		.config_init	= yt8521_config_init,
+		.read_status	= yt8521_read_status,
+		.suspend	= genphy_suspend,
+		.resume		= genphy_resume,
 	}, {
 		PHY_ID_MATCH_EXACT(PHY_ID_YT8522),
 		.name           = "YT8522 100M Ethernet",
@@ -1250,6 +1269,7 @@ MODULE_AUTHOR("Peter Geis");
 MODULE_LICENSE("GPL");
 
 static const struct mdio_device_id __maybe_unused motorcomm_tbl[] = {
+	{ PHY_ID_MATCH_EXACT(PHY_ID_MAE0621A) },
 	{ PHY_ID_MATCH_EXACT(PHY_ID_YT8511) },
 	{ PHY_ID_MATCH_EXACT(PHY_ID_YT8512) },
 	{ PHY_ID_MATCH_EXACT(PHY_ID_YT8512B) },
